# Copy this file to .env.local for local testing.
# For production, add the same keys in Vercel Environment Variables.

# Your Google account email
GMAIL_USER=your-email@gmail.com

# Google App Password (not your normal Gmail password)
GMAIL_APP_PASSWORD=your-16-char-app-password


# Where contact form messages should be delivered
MAIL_TO=your-email@gmail.com

# Optional override for sender identity
MAIL_FROM="Portfolio Contact <your-email@gmail.com>"
